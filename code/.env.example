# ──────────────────────────────────────────────────────────────────────────
# Variables d'environnement — Plateforme de financement sportif
# Copier ce fichier en .env.local (jamais commiter .env.local)
# ──────────────────────────────────────────────────────────────────────────

# --- Supabase ---------------------------------------------------------------

# URL du projet Supabase (visible dans Project Settings > API). Utilisée par
# le client public et le client serveur.
NEXT_PUBLIC_SUPABASE_URL=

# Clé "anon" publique Supabase. Exposée au navigateur (préfixe NEXT_PUBLIC_),
# protégée uniquement par les policies RLS — ne JAMAIS y mettre de logique de
# confiance côté serveur.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé "service_role" Supabase. Contourne RLS — usage SERVEUR UNIQUEMENT
# (webhooks, cron, scripts admin). Ne jamais exposer au client, ne jamais
# préfixer NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ------------------------------------------------------------------

# Clé secrète Stripe (sk_...). Usage serveur uniquement : création de sessions
# Checkout, appels API Stripe.
STRIPE_SECRET_KEY=

# Clé publique Stripe (pk_...). Exposée au navigateur pour initialiser
# Stripe.js côté client.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Secret de signature du webhook Stripe (whsec_...). Sert à vérifier que les
# évènements reçus sur /api/webhooks/stripe proviennent bien de Stripe avant
# de déclencher un crédit.
STRIPE_WEBHOOK_SECRET=

# --- SendGrid ------------------------------------------------------------------

# Clé API SendGrid pour l'envoi de courriels transactionnels (confirmations
# de commande, reçus, relances de campagne).
SENDGRID_API_KEY=

# Adresse expéditeur vérifiée dans SendGrid (domaine authentifié). Utilisée
# comme "From" sur tous les courriels sortants.
SENDGRID_FROM_EMAIL=

# --- Application ------------------------------------------------------------------

# URL publique de base de l'application (ex: https://exemple.com en prod,
# http://localhost:3000 en dev). Utilisée pour générer des liens absolus
# (courriels, redirections Stripe Checkout success/cancel).
NEXT_PUBLIC_APP_URL=http://localhost:3000
